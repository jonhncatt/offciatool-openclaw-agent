  {
    "name": "helper_route_rules_simple_understanding",
    "kind": "helper",
    "helper": "_route_request_by_rules",
    "args": {
      "user_message": "请解读这个 Atom 文件，并总结重点。",
      "attachment_metas": [
        {
          "original_name": "sample.atom",
          "suffix": ".atom",
          "kind": "document",
          "size": 1024
        }
      ],
      "settings": {
        "__type": "ChatSettings",
        "enable_tools": true,
        "response_style": "short"
      }
    },
    "assert": {
      "equals": {
        "task_type": "simple_understanding",
        "specialists.0": "summarizer",
        "use_planner": false,
        "use_worker_tools": false,
        "use_reviewer": false,
        "use_structurer": false
      }
    }
  },
