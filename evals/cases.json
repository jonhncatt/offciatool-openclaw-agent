  {
    "name": "helper_sanitize_final_answer_removes_internal_meta_for_inline_xml",
    "kind": "helper",
    "helper": "_sanitize_final_answer_text",
    "args": {
      "text": "当前处于evidence_required_mode=true,且 reviewer_verdict=block，由于你仅提供了xml文本内容，没有提供可供工具读取或搜索的本地文件路径，我无法进行可复核的解析。请提供路径。",
      "user_message": "请分析这段 XML 文本。\n<?xml version=\"1.0\" encoding=\"utf-8\"?>\n<feed>\n  <title>Example Feed</title>\n  <entry>\n    <title>Atom-Powered Robots Run Amok</title>\n    <summary>Some text about robots.</summary>\n  </entry>\n</feed>",
      "attachment_metas": []
    },
    "assert": {
      "contains": {
        "result": [
          "不需要额外提供本地文件路径"
        ]
      },
      "not_contains": {
        "result": [
          "evidence_required_mode",
          "reviewer_verdict",
          "本地文件路径，我无法进行可复核的解析"
        ]
      },
      "contains_any": {
        "result": [
          "解释的结构",
          "字段或结论"
        ]
      }
    }
  },
  {
    "name": "helper_route_rules_evidence_lookup",
