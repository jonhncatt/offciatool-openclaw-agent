  {
    "name": "helper_validation_context_web_tools_success",
    "kind": "helper",
    "helper": "_summarize_validation_context",
    "args": {
      "tool_events": [
        {
          "__type": "ToolEvent",
          "name": "search_web",
          "input": {
            "query": "latest openai news"
          },
          "output_preview": "{\"ok\": true, \"query\": \"latest openai news\", \"engine\": \"duckduckgo_html\", \"count\": 3}"
        },
        {
          "__type": "ToolEvent",
          "name": "fetch_web",
          "input": {
            "url": "https://example.com/story"
          },
          "output_preview": "{\"ok\": true, \"url\": \"https://example.com/story\", \"source_format\": \"html_text_extracted\", \"length\": 1200}"
        }
      ]
    },
    "assert": {
      "equals": {
        "web_tools_used": true,
        "web_tools_success": true
      },
      "contains_any": {
        "web_tool_notes.0": [
          "search_web",
          "fetch_web"
        ]
      }
    }
  },
  {
    "name": "helper_finalize_citations_prefers_fetched_web_evidence",
    "kind": "helper",
    "helper": "_finalize_citation_candidates",
    "args": {
      "citations": [
        {
          "source_type": "web",
          "tool": "search_web",
          "label": "Candidate result",
          "url": "https://search.example/candidate",
          "locator": "query=shohei ohtani japan",
          "excerpt": "Search snippet only",
          "confidence": "low"
        },
        {
          "source_type": "web",
          "tool": "fetch_web",
          "label": "Fetched article",
          "url": "https://news.example/story",
          "locator": "https://news.example/story",
          "excerpt": "Shohei Ohtani arrived in Japan this week.",
          "confidence": "high"
        }
      ]
    },
    "assert": {
      "equals": {
        "result.0.tool": "fetch_web",
        "result.0.id": "c1"
      }
    }
  },
  {
    "name": "helper_normalize_claim_record_downgrades_search_candidates",
    "kind": "helper",
    "helper": "_normalize_claim_record",
    "args": {
      "statement": "大谷翔平最近在日本国内。",
      "citation_ids": [
        "c1"
      ],
      "confidence": "high",
      "status": "supported",
      "citations_by_id": {
        "c1": {
          "id": "c1",
          "kind": "candidate",
          "tool": "search_web",
          "confidence": "low"
        }
      }
    },
    "assert": {
      "equals": {
        "status": "needs_review",
        "confidence": "low"
      }
    }
  },
